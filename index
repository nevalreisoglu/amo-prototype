<script>
// ─── DATA ───────────────────────────────────────────────────────
const prospects = [
  {id:'P-1001',name:'Ahmet Yılmaz',company:'TechRetail A.Ş.',size:'SME',industry:'Retail',product:'Fiber',behavior:'Website Visit',sizeScore:20,indScore:15,prodScore:25,behScore:10},
  {id:'P-1002',name:'Sarah Mitchell',company:'GlobalFinance Corp',size:'Enterprise',industry:'Finance',product:'Cloud',behavior:'Pricing Page',sizeScore:40,indScore:30,prodScore:35,behScore:25},
  {id:'P-1003',name:'Marco Rossi',company:'LogiFlow Ltd',size:'SME',industry:'Logistics',product:'IoT',behavior:'None',sizeScore:20,indScore:20,prodScore:20,behScore:0},
  {id:'P-1004',name:'Zeynep Kaya',company:'MegaTelekom',size:'Enterprise',industry:'Telecom',product:'Fiber',behavior:'Demo Request',sizeScore:40,indScore:35,prodScore:30,behScore:40},
  {id:'P-1005',name:'James Cooper',company:'HealthTech Inc',size:'Mid-Market',industry:'Healthcare',product:'Cloud',behavior:'Webinar',sizeScore:30,indScore:25,prodScore:30,behScore:15},
  {id:'P-1006',name:'Fatma Demir',company:'EduSmart',size:'SME',industry:'Education',product:'IoT',behavior:'Email Open',sizeScore:20,indScore:10,prodScore:15,behScore:8},
];

const avatarColors=[
  ['#f26522','#7a3010'],['#4a9eff','#1a3a6a'],['#00e5a0','#006644'],
  ['#ffd166','#7a6010'],['#b96eff','#4a2070'],['#ff7eb3','#7a2040']
];

const campaigns={
  high:{
    name:'Enterprise Acquisition Campaign',type:'Acquisition',channel:'Email + LinkedIn + SDR Call',priority:'🔴 High Priority',
    subject:'Transform Your Business with Enterprise-Grade Solutions',
    body:"Dear {name},\n\nOur AI has identified your company as an ideal fit for our Enterprise solutions. Based on your recent activity, we'd like to schedule a personalized executive briefing.\n\nLet's discuss how we can accelerate your digital transformation."
  },
  mid:{
    name:'Nurturing Journey — Mid-Market',type:'Nurture',channel:'Email Sequence',priority:'🟡 Medium Priority',
    subject:'Discover How {company} Can Scale with Our Platform',
    body:"Hi {name},\n\nWe noticed your interest in our solutions. We've curated a set of resources and case studies specifically relevant to the {industry} industry.\n\nReady to explore the possibilities?"
  },
  low:{
    name:'Awareness Campaign',type:'Awareness',channel:'Retargeting Ads',priority:'🟢 Low Priority',
    subject:'See What\'s New at Our Platform',
    body:"Hi {name},\n\nThank you for your interest! We'd love to share some resources about how companies like yours are benefiting from modern digital solutions."
  }
};

const owners=['Sarah K. (Enterprise Sales)','Mike R. (SMB Team)','Lisa T. (Mid-Market)','Ahmed B. (Enterprise Sales)'];

// ─── STATE ───────────────────────────────────────────────────────
let selectedProspect=null;
let campaignsFired=0;
let converted=0;
let currentEventPts=0;
let pipelineRunning=false;
let logTime=0;

// ─── INIT ────────────────────────────────────────────────────────
function init(){
  renderTable();
  renderSidebar();
}

function renderTable(){
  const tbody=document.getElementById('prospect-table');
  tbody.innerHTML='';
  prospects.forEach((p,i)=>{
    const baseScore=p.sizeScore+p.indScore+p.prodScore+p.behScore;
    const pct=Math.min(100,baseScore/140*100);
    const col=avatarColors[i%avatarColors.length];
    const fillCol=baseScore>70?'var(--orange)':baseScore>40?'var(--yellow)':'var(--text3)';
    const tr=document.createElement('tr');
    tr.onclick=()=>selectProspect(i,tr);
    tr.dataset.idx=i;
    tr.innerHTML=`
      <td class="mono">${p.id}</td>
      <td style="font-weight:600;color:var(--text)">${p.company}</td>
      <td><span class="badge ${p.size==='Enterprise'?'badge-ent':'badge-sme'}">${p.size}</span></td>
      <td>${p.industry}</td>
      <td>${p.product}</td>
      <td>${p.behavior}</td>
      <td>
        <div class="score-bar-wrap">
          <div class="score-mini"><div class="score-mini-fill" style="width:${pct}%;background:${fillCol}"></div></div>
          <span class="mono" style="font-size:10px;color:${fillCol}">${baseScore}</span>
        </div>
      </td>`;
    tbody.appendChild(tr);
  });
}

function renderSidebar(){
  const el=document.getElementById('sidebar-prospects');
  el.innerHTML='';
  prospects.forEach((p,i)=>{
    const baseScore=p.sizeScore+p.indScore+p.prodScore+p.behScore;
    const col=avatarColors[i%avatarColors.length];
    const scoreCol=baseScore>70?'var(--orange)':baseScore>40?'var(--yellow)':'var(--text3)';
    const div=document.createElement('div');
    div.className='prospect-item';
    div.dataset.idx=i;
    div.onclick=()=>selectProspect(i,null);
    div.innerHTML=`
      <div class="p-avatar" style="background:${col[1]};color:${col[0]}">${p.name.split(' ').map(n=>n[0]).join('')}</div>
      <div class="p-info">
        <div class="p-name">${p.name}</div>
        <div class="p-company">${p.company}</div>
      </div>
      <div class="p-score-badge" style="background:rgba(242,101,34,0.1);color:${scoreCol}">${baseScore}</div>`;
    el.appendChild(div);
  });
}

// ─── SELECT PROSPECT ─────────────────────────────────────────────
function selectProspect(idx, tr){
  if(pipelineRunning) return;
  selectedProspect=prospects[idx];

  // highlight table row
  document.querySelectorAll('#prospect-table tr').forEach(r=>r.classList.remove('highlighted'));
  document.querySelectorAll('.prospect-item').forEach(r=>r.classList.remove('selected'));
  if(tr) tr.classList.add('highlighted');
  document.querySelectorAll('.prospect-item').forEach(r=>{
    if(parseInt(r.dataset.idx)===idx) r.classList.add('selected');
  });
  document.querySelectorAll('#prospect-table tr').forEach(r=>{
    if(parseInt(r.dataset.idx)===idx) r.classList.add('highlighted');
  });

  // reset event buttons
  document.querySelectorAll('.event-btn').forEach(b=>b.classList.remove('fired'));

  // show banner
  const col=avatarColors[idx%avatarColors.length];
  document.getElementById('selected-banner').style.display='flex';
  document.getElementById('selected-banner').className='selected-prospect-banner';
  document.getElementById('selected-banner').innerHTML=`
    <div class="spb-avatar" style="background:${col[1]};color:${col[0]}">${selectedProspect.name.split(' ').map(n=>n[0]).join('')}</div>
    <div class="spb-info">
      <div class="spb-name">${selectedProspect.name} — ${selectedProspect.company}</div>
      <div class="spb-meta">${selectedProspect.size} · ${selectedProspect.industry} · Interest: ${selectedProspect.product}</div>
    </div>
    <span style="font-size:11px;color:var(--text3)">Select an event below ↓</span>`;

  // reset pipeline
  resetPipeline(false);
  addLog('INFO','PROSPECT',`Selected: <strong>${selectedProspect.name}</strong> (${selectedProspect.company}) — Base score loaded`,'info');
}

// ─── FIRE EVENT ──────────────────────────────────────────────────
function fireEvent(type, pts, icon){
  if(!selectedProspect){showToast('⚠️ Select a prospect first','Please click a row in the prospect table.','warn');return;}
  if(pipelineRunning) return;

  currentEventPts=pts;
  const eventNames={whitepaper:'Downloaded Whitepaper',pricing:'Visited Pricing Page',demo:'Requested Demo',webinar:'Attended Webinar',email:'Opened Email Campaign',contact:'Contact Sales Form'};
  const eName=eventNames[type];

  // mark btn fired
  document.querySelectorAll('.event-btn').forEach(b=>b.classList.remove('fired'));
  event.currentTarget.classList.add('fired');

  addLog('INFO','EVENT',`<strong>${icon} ${eName}</strong> received for ${selectedProspect.name} (+${pts} pts)`,'info');
  runPipeline(eName, pts);
}

// ─── PIPELINE RUNNER ─────────────────────────────────────────────
async function runPipeline(eventName, eventPts){
  pipelineRunning=true;

  const p=selectedProspect;
  const totalScore=p.sizeScore+p.indScore+p.prodScore+p.behScore+eventPts;

  // Step 0: Prospect captured
  setStep(0,'running');
  await delay(600);
  document.getElementById('sub-0').textContent=p.id;
  setStep(0,'done');
  addLog('OK','CAPTURE',`Prospect profile loaded: <strong>${p.company}</strong> [${p.size}, ${p.industry}]`,'ok');
  await delay(300);

  // Step 1: Event trigger
  setStep(1,'running');
  await delay(700);
  document.getElementById('sub-1').textContent='+'+eventPts+' pts';
  setStep(1,'done');
  addLog('OK','EVENT',`Event processed: <strong>${eventName}</strong>. Score delta: +${eventPts}`,'ok');
  await delay(300);

  // Step 2: AI Scoring
  setStep(2,'running');
  addLog('AI','SCORE','Running lead scoring model...',  'ai');
  await delay(400);
  addLog('AI','SCORE',`Company size weight: <strong>+${p.sizeScore}</strong>`, 'ai');
  await delay(300);
  addLog('AI','SCORE',`Industry fit weight: <strong>+${p.indScore}</strong>`, 'ai');
  await delay(300);
  addLog('AI','SCORE',`Product interest weight: <strong>+${p.prodScore}</strong>`, 'ai');
  await delay(300);
  addLog('AI','SCORE',`Behavioral signal weight: <strong>+${p.behScore}</strong>`, 'ai');
  await delay(300);
  addLog('AI','SCORE',`Event bonus: <strong>+${eventPts}</strong>`, 'ai');
  await delay(400);
  addLog('OK','SCORE',`Final Lead Score: <strong>${totalScore}</strong>/200`, 'ok');
  document.getElementById('sub-2').textContent='Score: '+totalScore;
  setStep(2,'done');

  // Update KPIs
  document.getElementById('kpi-score').textContent=totalScore;
  let qual,qualSub,actionText,actionSub;
  if(totalScore>=80){
    qual='HIGH VALUE';qualSub='🔴 Acquisition Target';
    actionText='ACQUIRE';actionSub='Trigger acquisition campaign';
    document.getElementById('kpi-value')
  } else if(totalScore>=50){
    qual='QUALIFIED';qualSub='🟡 Nurture & Convert';
    actionText='NURTURE';actionSub='Send nurturing sequence';
  } else {
    qual='LOW';qualSub='🟢 Awareness needed';
    actionText='AWARE';actionSub='Retargeting campaign';
  }
  document.getElementById('kpi-qual').textContent=qual;
  document.getElementById('kpi-qual-sub').textContent=qualSub;
  document.getElementById('kpi-action').textContent=actionText;
  document.getElementById('kpi-action-sub').textContent=actionSub;

  await delay(400);

  // Step 3: Campaign selection
  setStep(3,'running');
  addLog('AI','DECIDE',`Score ${totalScore} → evaluating campaign decision tree...`, 'ai');
  await delay(600);

  let campKey=totalScore>=80?'high':totalScore>=50?'mid':'low';
  const camp=campaigns[campKey];
  document.getElementById('sub-3').textContent=campKey.toUpperCase();
  setStep(3,'done');
  addLog('OK','DECIDE',`Campaign selected: <strong>${camp.name}</strong>`, 'ok');
  await delay(300);

  // Step 4: Execution
  setStep(4,'running');
  const leadId='LEAD-'+Math.floor(Math.random()*9000+1000);
  const owner=owners[Math.floor(Math.random()*owners.length)];
  addLog('OK','LEAD',`Lead created: <strong>${leadId}</strong>. Owner: ${owner}`, 'ok');
  await delay(500);
  addLog('OK','CAMPAIGN',`Campaign <strong>"${camp.name}"</strong> triggered via ${camp.channel}`, 'ok');
  await delay(400);
  addLog('OK','NOTIFY',`Sales team notified. Status: <strong>OPEN</strong>`, 'ok');
  document.getElementById('sub-4').textContent='LAUNCHED';
  setStep(4,'done');

  // Fill result cards
  document.getElementById('lead-card').classList.add('revealed');
  document.getElementById('campaign-card').classList.add('revealed');
  document.getElementById('lead-status-badge').style.display='inline-flex';
  document.getElementById('camp-status-badge').style.display='inline-flex';

  document.getElementById('res-lead-id').textContent=leadId;
  document.getElementById('res-company').textContent=p.company;
  document.getElementById('res-status').textContent='● Open — Assigned';
  document.getElementById('res-owner').textContent=owner;

  // Score bars
  setTimeout(()=>{
    const maxPts=50;
    setBar('sb-size','sbv-size',p.sizeScore,maxPts);
    setBar('sb-ind','sbv-ind',p.indScore,maxPts);
    setBar('sb-prod','sbv-prod',p.prodScore,maxPts);
    setBar('sb-beh','sbv-beh',p.behScore+eventPts,maxPts);
    document.getElementById('score-gauge-fill').style.width=Math.min(100,totalScore/140*100)+'%';
    document.getElementById('total-score-display').textContent=totalScore+' / 140+';
  },200);

  document.getElementById('res-campaign').textContent=camp.name;
  document.getElementById('res-camp-type').textContent=camp.type;
  document.getElementById('res-channel').textContent=camp.channel;
  document.getElementById('res-priority').textContent=camp.priority;

  const emailEl=document.getElementById('email-preview');
  emailEl.style.display='block';
  document.getElementById('email-subject').textContent=camp.subject.replace('{company}',p.company);
  document.getElementById('email-body').textContent=camp.body.replace('{name}',p.name.split(' ')[0]).replace('{company}',p.company).replace('{industry}',p.industry);

  // stats
  campaignsFired++;
  document.getElementById('stat-campaigns').textContent=campaignsFired;
  if(totalScore>=80){converted++;document.getElementById('stat-converted').textContent=converted}

  showToast('🚀 Campaign Launched!', `${camp.name} triggered for ${p.company}`, 'ok');
  pipelineRunning=false;
}

// ─── HELPERS ─────────────────────────────────────────────────────
function setStep(idx, state){
  const node=document.getElementById('node-'+idx);
  const step=document.getElementById('step-'+idx);
  node.className='flow-node '+state;
  step.className='flow-step '+(state==='done'?'complete':state==='running'?'active':'');
}

function setBar(fillId, valId, val, max){
  document.getElementById(fillId).style.width=Math.min(100,val/max*100)+'%';
  document.getElementById(valId).textContent=val;
}

function addLog(type, tag, msg, cls){
  logTime+=Math.floor(Math.random()*3+1);
  const hh=String(Math.floor(logTime/60)).padStart(2,'0');
  const mm=String(logTime%60).padStart(2,'0');
  const body=document.getElementById('log-body');

  // Remove cursor from last line
  body.querySelectorAll('.log-cursor').forEach(c=>c.remove());

  const line=document.createElement('div');
  line.className='log-line';
  const tagClass={'info':'tag-info','ok':'tag-ok','ai':'tag-ai','warn':'tag-warn'}[cls]||'tag-info';
  line.innerHTML=`<span class="log-time">${hh}:${mm}:${String(Math.floor(Math.random()*59)).padStart(2,'0')}</span><span class="log-tag ${tagClass}">${tag}</span><span class="log-msg">${msg}<span class="log-cursor"></span></span>`;
  body.appendChild(line);
  body.scrollTop=body.scrollHeight;
}

function delay(ms){return new Promise(r=>setTimeout(r,ms))}

function resetPipeline(full=true){
  for(let i=0;i<5;i++){setStep(i,'idle');document.getElementById('sub-'+i).textContent='—';}
  if(full){
    document.getElementById('lead-card').classList.remove('revealed');
    document.getElementById('campaign-card').classList.remove('revealed');
    document.getElementById('lead-status-badge').style.display='none';
    document.getElementById('camp-status-badge').style.display='none';
    document.getElementById('email-preview').style.display='none';
    ['res-lead-id','res-company','res-status','res-owner','res-campaign','res-camp-type','res-channel','res-priority'].forEach(id=>document.getElementById(id).textContent='—');
    document.getElementById('score-gauge-fill').style.width='0%';
    document.getElementById('total-score-display').textContent='—';
    ['sb-size','sb-ind','sb-prod','sb-beh'].forEach(id=>document.getElementById(id).style.width='0%');
    ['sbv-size','sbv-ind','sbv-prod','sbv-beh'].forEach(id=>document.getElementById(id).textContent='0');
    document.getElementById('kpi-score').textContent='—';
    document.getElementById('kpi-qual').textContent='—';
    document.getElementById('kpi-qual-sub').textContent='Awaiting AI scoring';
    document.getElementById('kpi-action').textContent='—';
    document.getElementById('kpi-action-sub').textContent='No event triggered yet';
  }
}

function resetAll(){
  pipelineRunning=false;
  selectedProspect=null;
  currentEventPts=0;
  document.getElementById('selected-banner').style.display='none';
  document.querySelectorAll('#prospect-table tr').forEach(r=>r.classList.remove('highlighted'));
  document.querySelectorAll('.prospect-item').forEach(r=>r.classList.remove('selected'));
  document.querySelectorAll('.event-btn').forEach(b=>b.classList.remove('fired'));
  resetPipeline(true);
  const body=document.getElementById('log-body');
  body.innerHTML='';
  logTime=0;
  addLog('INFO','SYS','AMO Engine reset. Awaiting event trigger...','info');
}

let toastTimer;
function showToast(header, body, type){
  const el=document.getElementById('toast');
  document.getElementById('toast-header').innerHTML=header;
  document.getElementById('toast-body').textContent=body;
  el.style.borderColor=type==='ok'?'rgba(0,229,160,0.3)':type==='warn'?'rgba(255,209,102,0.3)':'var(--border)';
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>el.classList.remove('show'),4000);
}

init();
</script>
